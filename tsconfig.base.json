{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@ndtech/shared": ["packages/shared/src/index.ts"],
      "@ndtech/firmware-tools": ["packages/firmware-tools/src/index.ts"],
      "@ndtech/branding-engine": ["packages/branding-engine/src/index.ts"],
      "@ndtech/core": ["packages/core/src/index.ts"]
    }
  }
}
