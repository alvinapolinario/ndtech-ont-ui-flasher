# Docker Compose configuration — copy to ".env" next to docker-compose.yml.
#
# PUBLIC_API_URL is the address the BROWSER will use to reach the API container.
# It is baked into the web bundle at build time, so set it BEFORE `docker compose build`.
# It must include the PUBLISHED api host port (API_PORT_HOST below, default 4001).
#
#   - Local test on the server itself:   http://localhost:4001
#   - Access from other machines (LAN):  http://192.168.1.50:4001   (your server IP)
#   - Behind a domain:                   https://ont.example.com/api-host...
#
# If you change this, rebuild: `docker compose build` (a plain `up` won't re-bake it).
PUBLIC_API_URL=http://localhost:4001

# Published host ports (containers still listen internally on 3000/4000).
WEB_PORT=3003
API_PORT_HOST=4001
