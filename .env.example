# ----------------------------------------------------------------------------
# NDTECH Huawei ONT Web UI Customizer - environment configuration
# Copy this file to ".env" and adjust values for your machine.
# ----------------------------------------------------------------------------

# Prisma / SQLite database location.
# NOTE: for SQLite, Prisma resolves this path relative to the schema.prisma file
# (packages/core/prisma/), so this points back to <repo-root>/storage/ndtech.db.
DATABASE_URL="file:../../../storage/ndtech.db"

# API server
API_PORT=4000
API_HOST=127.0.0.1

# Public base URL of the API, consumed by the Next.js web app
NEXT_PUBLIC_API_URL="http://127.0.0.1:4000"

# Absolute or relative path to the storage root used for uploads/workspaces/exports
STORAGE_ROOT="./storage"

# Maximum firmware upload size in bytes (default 256 MiB)
MAX_UPLOAD_BYTES=268435456

# Set to "true" to allow potentially destructive repack helpers to actually run.
# When false (default) the tool only SUGGESTS commands and never executes mksquashfs.
ALLOW_REPACK_EXECUTION=false

# Set to "true" to force mock/demo mode even if external tools are installed.
# Useful for testing the UI on Windows/macOS without binwalk etc.
FORCE_MOCK_MODE=false

# WSL bridge (Windows only): when the Linux firmware tools are not available
# natively but ARE installed inside WSL, the app runs them through WSL and
# translates Windows paths automatically. Leave WSL_DISTRO empty to use WSL's
# default distro, or set it to target a specific one (e.g. "Ubuntu").
# See docs/WSL-SETUP.md.
WSL_DISTRO=
